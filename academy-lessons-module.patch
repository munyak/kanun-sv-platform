+-- ============================================================
+-- KaNun Academy — Lesson Feedback & Cache Tables
+-- Migration 0010
+-- ============================================================
+
+-- Lesson content cache — stores generated lessons for consistency
+CREATE TABLE IF NOT EXISTS academy_lesson_cache (
+  id            uuid DEFAULT gen_random_uuid() PRIMARY KEY,
+  org_id        uuid REFERENCES organizations(id) ON DELETE CASCADE,
+  domain_id     int NOT NULL,
+  topic_index   int NOT NULL,
+  topic_name    text NOT NULL,
+  content_json  jsonb NOT NULL,         -- full lesson JSON from LLM
+  version       int DEFAULT 1,
+  generated_at  timestamptz DEFAULT now(),
+  UNIQUE(org_id, domain_id, topic_index)
+);
+ALTER TABLE academy_lesson_cache ENABLE ROW LEVEL SECURITY;
+CREATE POLICY "org members can read lessons"
+  ON academy_lesson_cache FOR SELECT
+  USING (org_id IN (SELECT org_id FROM profiles WHERE id = auth.uid()));
+
+-- Lesson feedback — reviewer ratings and comments per section
+CREATE TABLE IF NOT EXISTS academy_lesson_feedback (
+  id            uuid DEFAULT gen_random_uuid() PRIMARY KEY,
+  user_id       uuid REFERENCES auth.users(id) ON DELETE CASCADE NOT NULL,
+  org_id        uuid REFERENCES organizations(id) ON DELETE CASCADE,
+  lesson_cache_id uuid REFERENCES academy_lesson_cache(id) ON DELETE CASCADE,
+  domain_id     int NOT NULL,
+  topic_index   int NOT NULL,
+  section_id    text NOT NULL,
+  rating        int CHECK (rating BETWEEN 1 AND 4),
+  comment       text,
+  status        text DEFAULT 'pending' CHECK (status IN ('pending','reviewed','applied')),
+  created_at    timestamptz DEFAULT now()
+);
+ALTER TABLE academy_lesson_feedback ENABLE ROW LEVEL SECURITY;
+CREATE POLICY "users can manage own feedback"
+  ON academy_lesson_feedback FOR ALL
+  USING (user_id = auth.uid());
+
+-- Indexes
+CREATE INDEX idx_lesson_cache_org_domain ON academy_lesson_cache(org_id, domain_id);
+CREATE INDEX idx_lesson_feedback_user ON academy_lesson_feedback(user_id, domain_id);
+CREATE INDEX idx_lesson_feedback_lesson ON academy_lesson_feedback(lesson_cache_id);
