+  font-size: 12px;
+  color: var(--text-secondary);
+}
+.domain-learn-progress {
+  display: flex;
+  align-items: center;
+  gap: 8px;
+}
+.domain-pct {
+  font-size: 16px;
+  font-weight: 700;
+  color: var(--text-primary);
+}
+.domain-progress-ring {
+  width: 40px;
+  height: 40px;
+}
+.domain-progress-ring svg {
+  transform: rotate(-90deg);
+  width: 100%;
+  height: 100%;
+}
+
+/* Topic lesson links */
+.domain-topic-list {
+  display: flex;
+  flex-direction: column;
+  gap: 4px;
+  margin-bottom: 16px;
+}
+.topic-lesson-link {
+  display: flex;
+  align-items: center;
+  gap: 12px;
+  padding: 10px 14px;
+  border-radius: var(--r-md);
+  text-decoration: none;
+  color: var(--text-primary);
+  font-size: 14px;
+  transition: background 0.15s ease;
+}
+.topic-lesson-link:hover { background: var(--surface-secondary); }
+.topic-status {
+  width: 24px;
+  height: 24px;
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  border-radius: 50%;
+  background: var(--border-default);
+  font-size: 12px;
+  font-weight: 600;
+  color: var(--text-secondary);
+  flex-shrink: 0;
+}
+.topic-lesson-link.done .topic-status {
+  background: #dcfce7;
+  color: #16a34a;
+}
+.topic-name { flex: 1; }
+.topic-action {
+  font-size: 12px;
+  color: var(--text-secondary);
+  font-weight: 500;
+  opacity: 0;
+  transition: opacity 0.15s ease;
+}
+.topic-lesson-link:hover .topic-action { opacity: 1; }
+
+/* Domain footer */
+.domain-learn-footer {
+  display: flex;
+  gap: 8px;
+  padding-top: 12px;
+  border-top: 1px solid var(--border-default);
+}
+
+/* Tier enrolled state */
+.tier-enrolled {
+  font-size: 13px;
+  font-weight: 600;
+  color: #16a34a;
+  margin-top: 12px;
+}
+
+/* ---------- Responsive ---------- */
+@media (max-width: 768px) {
+  .lesson-layout {
+    flex-direction: column;
+  }
+  .lesson-sidebar {
+    width: 100%;
+    position: static;
+    display: flex;
+    gap: 4px;
+    overflow-x: auto;
+    padding-bottom: 8px;
+  }
+  .lesson-sidebar-title { display: none; }
+  .lesson-nav-item {
+    white-space: nowrap;
+    flex-shrink: 0;
+  }
+  .lesson-section {
+    padding: 20px 16px;
+  }
+  .enrollment-tiers {
+    flex-direction: column;
+    align-items: stretch;
+  }
+  .enroll-tier-btn {
+    flex-direction: row;
+    justify-content: space-between;
+  }
+}
